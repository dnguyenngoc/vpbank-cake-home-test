AIRFLOW_PROJ_DIR=./airflow
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7

# SFTP Sync Connections - Auto-create Airflow connections
AIRFLOW_CONN_SFTP_SYNC_SOURCE_CONN_ID=sftp://testuser:testpass@sftp-source:22
AIRFLOW_CONN_SFTP_SYNC_TARGET_CONN_ID=sftp://testuser:testpass@sftp-target:22

# SFTP Sync Variables - Connection IDs for DAG
AIRFLOW_VAR_SFTP_SYNC_SOURCE_CONN_ID=sftp_sync_source_conn_id
AIRFLOW_VAR_SFTP_SYNC_TARGET_CONN_ID=sftp_sync_target_conn_id
